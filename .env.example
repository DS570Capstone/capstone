# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=liftlens
POSTGRES_PASSWORD=liftlens_secret
POSTGRES_DB=liftlens
POSTGRES_PORT=5432

# ── MinIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=videos
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Kafka ────────────────────────────────────────────────
KAFKA_PORT=9092
KAFKA_UI_PORT=8090

# ── API ──────────────────────────────────────────────────
API_PORT=5050

# ── WandB (optional — set WANDB_ENABLED=false to skip) ───
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=liftlens-ohp
WANDB_ENABLED=false

# ── HuggingFace (required only if vlm.enabled=true) ──────
HF_TOKEN=your_huggingface_token_here

# ── ML ───────────────────────────────────────────────────
ML_ROOT=/app/ml
